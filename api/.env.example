# --- API runtime ---
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000
MAX_CONCURRENT_JUDGE_RUNS=2

# --- Ollama ---
# OLLAMA_HOST points at the ollama server. The three *_MODEL env vars are
# Ollama tags you've pulled (check with: ollama list).
#
# Recommended split:
#   - Knowledge / Style: NON-thinking instruction-tuned models (gemma2:9b,
#     llama3.2:3b, qwen2.5:7b-instruct). User waits on these, so every CoT
#     token is wall-clock latency for nothing — the thinking text is stripped
#     before display.
#   - Judge: thinking is FINE here. The Judge emits structured JSON we parse,
#     and CoT improves verdict quality. Pick a different model FAMILY from
#     Knowledge/Style to break self-preference bias (Zheng et al. 2023).
OLLAMA_HOST=http://localhost:11434
KNOWLEDGE_MODEL=gemma4:latest
STYLE_MODEL=gemma4:latest
JUDGE_MODEL=rnj-1:latest

# --- Judge orchestrator tuning (optional; absent = use judge/config.py defaults) ---
# MAX_REVISIONS=2
# JUDGE_STYLE_PASS_THRESHOLD=4
# CONTENT_PRESERVATION_MIN=0.70
# TOP_K=5
# MAX_NEW_TOKENS=256
