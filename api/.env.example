# --- API runtime ---
API_HOST=0.0.0.0
API_PORT=8000
ALLOWED_ORIGINS=http://localhost:3000
MAX_CONCURRENT_JUDGE_RUNS=2

# --- Ollama ---
# OLLAMA_HOST points at the ollama server. The three *_MODEL env vars are
# Ollama tags you've pulled (check with: ollama list). Routing Judge to a
# different model family than Knowledge/Style breaks self-preference bias.
OLLAMA_HOST=http://localhost:11434
KNOWLEDGE_MODEL=gemma4:latest
STYLE_MODEL=gemma4:latest
JUDGE_MODEL=rnj-1:latest

# --- Judge orchestrator tuning (optional; absent = use judge/config.py defaults) ---
# MAX_REVISIONS=2
# JUDGE_STYLE_PASS_THRESHOLD=4
# CONTENT_PRESERVATION_MIN=0.70
# TOP_K=5
# MAX_NEW_TOKENS=256
